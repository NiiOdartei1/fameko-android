<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16.dp"
    android:background="#F8F9FA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="Driver Profile" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24.dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16.dp"
                app:cardElevation="2.dp"
                app:contentPadding="16.dp"
                android:layout_marginBottom="16.dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvDriverName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Driver Name"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDriverStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status: PENDING_DOCS"
                        android:textColor="#856404" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Required Documents"
                android:textStyle="bold"
                android:layout_marginBottom="8.dp" />

            <!-- Profile Pic -->
            <include
                android:id="@+id/layoutProfilePic"
                layout="@layout/item_doc_upload" />

            <!-- License -->
            <include
                android:id="@+id/layoutLicense"
                layout="@layout/item_doc_upload" />

            <!-- Ghana Card -->
            <include
                android:id="@+id/layoutGhanaCard"
                layout="@layout/item_doc_upload" />

            <!-- Insurance -->
            <include
                android:id="@+id/layoutInsurance"
                layout="@layout/item_doc_upload" />

            <!-- Roadworthy -->
            <include
                android:id="@+id/layoutRoadworthy"
                layout="@layout/item_doc_upload" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
