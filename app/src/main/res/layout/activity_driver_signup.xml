<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".DriverSignupActivity">

    <LinearLayout
        android:id="@+id/llProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/step1Indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStep1Circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/step_circle_active"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStep1Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Basic Info"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginTop="16dp"
            android:background="#000000" />

        <LinearLayout
            android:id="@+id/step2Indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStep2Circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/step_circle_inactive"
                android:gravity="center"
                android:text="2"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStep2Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Documents"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llProgress">

        <!-- Step 1: Basic Information -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Full Name"
                    app:boxStrokeColor="#000000"
                    app:hintTextColor="#000000">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="#000000" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Email Address"
                    app:boxStrokeColor="#000000"
                    app:hintTextColor="#000000">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="#000000" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Phone Number"
                    app:boxStrokeColor="#000000"
                    app:hintTextColor="#000000">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:textColor="#000000" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Driver's License Number"
                    app:boxStrokeColor="#000000"
                    app:hintTextColor="#000000">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLicenseNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#000000" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Region of Operation"
                    app:boxStrokeColor="#000000"
                    app:hintTextColor="#000000">

                    <AutoCompleteTextView
                        android:id="@+id/actRegion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="#000000" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Vehicle Type"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/llVehicleOptions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <!-- Bicycle -->
                        <LinearLayout
                            android:id="@+id/optionBicycle"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/vehicle_option_bg"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@raw/bicycle"
                                android:contentDescription="Bicycle" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Bicycle"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />
                        </LinearLayout>

                        <!-- Praggia -->
                        <LinearLayout
                            android:id="@+id/optionPraggia"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/vehicle_option_bg"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@raw/praggia"
                                android:contentDescription="Praggia" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Praggia"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />
                        </LinearLayout>

                        <!-- Abobo Yaa -->
                        <LinearLayout
                            android:id="@+id/optionAboboyaa"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/vehicle_option_bg"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@raw/aboboyaa"
                                android:contentDescription="Abobo Yaa" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Abobo Yaa"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />
                        </LinearLayout>

                        <!-- Motor Okada -->
                        <LinearLayout
                            android:id="@+id/optionOkada"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/vehicle_option_bg"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@raw/okada"
                                android:contentDescription="Motor Okada" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Motor Okada"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />
                        </LinearLayout>

                        <!-- Truck -->
                        <LinearLayout
                            android:id="@+id/optionTruck"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/vehicle_option_bg"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@raw/truck"
                                android:contentDescription="Truck" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Truck"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />
                        </LinearLayout>

                        <!-- Taxi/Car -->
                        <LinearLayout
                            android:id="@+id/optionCar"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/vehicle_option_bg"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@raw/car"
                                android:contentDescription="Taxi/Car" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Taxi/Car"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />
                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Service Type"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/llServiceOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">
                    <!-- Service options -->
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Vehicle Plate Number"
                    app:boxStrokeColor="#000000"
                    app:hintTextColor="#000000">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVehicleNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#000000" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Password"
                    app:boxStrokeColor="#000000"
                    app:hintTextColor="#000000"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="#000000" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Confirm Password"
                    app:boxStrokeColor="#000000"
                    app:hintTextColor="#000000"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="#000000" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextStep"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:padding="12dp"
                    android:text="Continue to Documents"
                    android:textAllCaps="false"
                    app:backgroundTint="#004E89"
                    app:cornerRadius="8dp" />

                <TextView
                    android:id="@+id/tvLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="Already a driver? Login here"
                    android:textColor="#000000"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Step 2: Document Verification -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#E3F2FD"
                    android:padding="12dp"
                    android:text="Please upload clear, readable images of all required documents. (Max 10MB each)"
                    android:textColor="#0D47A1"
                    android:textSize="13sp" />

                <!-- Profile Pic -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="1. Profile Picture"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProfilePic"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#F8F9FA"
                    app:strokeColor="#DEE2E6"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/ivProfilePic"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Profile Picture"
                            android:scaleType="centerInside"
                            android:src="@android:drawable/ic_menu_camera" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Driver's License -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="2. Driver's License"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLicense"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#F8F9FA"
                    app:strokeColor="#DEE2E6"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/ivLicense"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Driver's License"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_gallery" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Insurance -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="3. Vehicle Insurance Certificate"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardInsurance"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#F8F9FA"
                    app:strokeColor="#DEE2E6"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/ivInsurance"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Insurance Certificate"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_gallery" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Roadworthy -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="4. Roadworthiness Certificate"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRoadworthy"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#F8F9FA"
                    app:strokeColor="#DEE2E6"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/ivRoadworthy"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Roadworthy Certificate"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_gallery" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Ghana Card -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="5. Ghana Card"
                    android:textColor="#000000"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGhanaCard"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#F8F9FA"
                    app:strokeColor="#DEE2E6"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/ivGhanaCard"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Ghana Card"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_gallery" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBack"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        android:text="Back"
                        android:textAllCaps="false"
                        app:cornerRadius="8dp"
                        app:strokeColor="#004E89" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="2"
                        android:padding="12dp"
                        android:text="Complete Registration"
                        android:textAllCaps="false"
                        app:backgroundTint="#28A745"
                        app:cornerRadius="8dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </ViewFlipper>

</androidx.constraintlayout.widget.ConstraintLayout>
